# --- Frontend (Vite: må prefikses med VITE_) ---
# VITE_FIREBASE_* kan også leses fra firebase-applet-config.json lokalt.
# VITE_SCANNER_URL=https://din-tjeneste.run.app
# VITE_SCAN_SECRET=match SCAN_SECRET på serveren (hvis satt)

# --- Backend (server.ts, dotenv) ---
# Anbefalt: Firebase Admin (service account) — trenger ikke SCRAPER_EMAIL.
# Firebase Console → Prosjektinnstillinger → Service accounts → Generer ny privat nøkkel.
# Lagre JSON som firebase-adminsdk.json i prosjektmappa (allerede i .gitignore), eller:
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\sti\til\nøkkel.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternativ: e-post/passord-bruker som matcher firestore.rules (isAdmin).
SCRAPER_EMAIL=
SCRAPER_PASSWORD=

# Hemmelighet for POST /scan og /api/trigger-scraper (header x-scan-secret). Påkrevd i prod.
SCAN_SECRET=

# Varsel-e-post ved «kupp» (nodemailer). Tom = ingen utsending.
ALERT_EMAIL=

# Scanner / Finn (valgfritt)
# Standard søk: alle brukte biler. Sett FINN_CAR_SEARCH_URL for merke/modell/fylke.
# FINN_CAR_SEARCH_URL=
# ~50 annonser/side — for «alt» på Finn trengs typisk 1200–2000 sider:
# FINN_MAX_SEARCH_PAGES=1500
# Stopp paginering etter N sider på rad uten nye annonser (default 6)
# FINN_MAX_EMPTY_PAGES=8
# FINN_PAGE_DELAY_MS=1500
# Åpne annonser for km/år/farge (tregt i bulk): FINN_DEEP_SCRAPE_MAX=500

# Én avsluttet sync uten webserver: npm run scrape (eller SCRAPE_ONCE=1)

# Kjør ikke automatisk scraper ved serverstart (local dev): RUN_SCRAPER_ON_START=false
# RUN_SCRAPER_ON_START=true

# PORT=3000

GEMINI_API_KEY=MY_GEMINI_API_KEY
APP_URL=MY_APP_URL
